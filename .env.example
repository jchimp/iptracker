# ── iptracker configuration ──────────────────────────────────────
#
# Copy to .env and edit as needed:
#   cp .env.example .env
#

# Host port for the web UI
IPTRACKER_PORT=8080

# Flask secret key — generate a strong key for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# SQLite database path (inside the container / relative to app root)
# Default: data/iptracker.db  — mounted as a volume in docker-compose
# DATABASE_URL=sqlite:////app/data/iptracker.db

# Ping scan tuning
PING_TIMEOUT=1
MAX_WORKERS=64

# Timezone for display
TZ=America/Denver
